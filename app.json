{
  "expo": {
    "name": "BAACC at BCC",
    "slug": "keynote-bcc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.keynotebcc"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "17.6",
            "buildReactNativeFromSource": true
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Flego accede a la cámara de tu dispositivo para poder capturar evidencias de tus movimientos así como cargar documentos.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir a Flego utilizar FaceID para iniciar sesión con tu cuenta."
        }
      ]
    ]
  }
}