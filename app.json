{
  "expo": {
    "name": "BAACC at BCC",
    "slug": "keynote-bcc",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "icon": {
        "light": "./assets/images/logos/light.png",
        "dark": "./assets/images/logos/transparent.png"
      },
      "bundleIdentifier": "com.anonymous.keynotebcc"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logos/android.png",
        "monochromeImage": "./assets/images/logos/android.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.keynotebcc",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "17.6",
            "buildReactNativeFromSource": true
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Flego accede a la cámara de tu dispositivo para poder capturar evidencias de tus movimientos así como cargar documentos.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir a Flego utilizar FaceID para iniciar sesión con tu cuenta."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/logos/transparent.png",
          "resizeMode": "contain",
          "imageWidth": 200
        }
      ]
    ]
  }
}